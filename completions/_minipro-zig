#compdef minipro-zig

_minipro_zig() {
  local -a commands
  commands=(
    'programmer:programmer commands'
    'db:database commands'
    'device:device database commands'
    'chip:chip operation commands'
    'logic:logic IC commands'
  )
  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '--db[SQLite database path]:database:_files' \
    '(-q --programmer)'{-q,--programmer}'[programmer family]:programmer:(auto tl866a tl866ii t48 t56 t76)' \
    '--json[emit JSON where supported]' \
    '--verbose[print extra diagnostics]' \
    '--quiet[reduce nonessential output]' \
    '(-Q --query_supported)'{-Q,--query_supported}'[list programmer families]' \
    '(-k --presence_check)'{-k,--presence_check}'[detect programmer]' \
    '-p[legacy device selector]:device:' \
    '-r[legacy read file]:file:_files' \
    '-w[legacy write file]:file:_files' \
    '-m[legacy verify file]:file:_files' \
    '-E[legacy erase]' \
    '-P[legacy protect]' \
    '-u[legacy unprotect]' \
    '-D[legacy read ID]' \
    '-b[legacy blank check]' \
    '-T[legacy logic test]' \
    '-a[legacy autodetect package size]:package:(8 16)' \
    '1:command:->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe 'command' commands
      ;;
    args)
      case $words[1] in
        programmer)
          _values 'programmer command' list detect info
          ;;
        db)
          _arguments \
            '1:db command:(import stats query)' \
            '--infoic[upstream infoic.xml path]:file:_files' \
            '--logicic[upstream logicic.xml path]:file:_files' \
            '--algorithms[optional algorithm.xml path]:file:_files' \
            '--out[output path]:file:_files'
          ;;
        device)
          _arguments '1:device command:(list search info)' '--limit[result limit]:count:'
          ;;
        chip)
          _arguments \
            '1:chip command:(read read-id autodetect blank verify erase write protect unprotect)' \
            '--device[device name]:device:' \
            '--in[input path]:file:_files' \
            '--out[output path]:file:_files' \
            '--format[file format]:format:(bin ihex srec config jedec)' \
            '--memory[memory kind]:memory:(code data user)' \
            '--package[SPI package size]:package:(8 16)' \
            '--execute[access hardware]' \
            '--confirm-destructive[confirm destructive operation]:device:'
          ;;
        logic)
          _arguments '1:logic command:(test)' '--device[device name]:device:' '--out[output path]:file:_files' '--execute[access hardware]'
          ;;
      esac
      ;;
  esac
}

_minipro_zig "$@"
