{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/opt/homebrew/Cellar/zig/**": "allow",
      "/opt/homebrew/Cellar/libusb/**": "allow",
      "/opt/homebrew/opt/zig/**": "allow",
      "/opt/homebrew/opt/libusb/**": "allow",
      "/var/folders/*/T/opencode/**": "allow",
      "~/.cache/zig/**": "allow",
      "~/.local/share/opencode/**": "allow",
      "~/repos/minipro/**": "allow",
      "~/repos/minipro-zig/**": "allow"
    },
    "bash": {
      "zig *": "allow",
      "zig": "allow",
      "/opt/homebrew/bin/zig *": "allow",
      "/opt/homebrew/bin/zig": "allow",
      "command -v zig": "allow",
      "command -v minipro": "allow",
      "which zig": "allow",
      "which minipro": "allow",
      "pkg-config *": "allow",
      "minipro *": "allow",
      "date": "allow",
      "git status *": "allow",
      "git status": "allow",
      "git diff *": "allow",
      "git diff": "allow",
      "git log *": "allow",
      "git log": "allow",
      "git remote *": "allow",
      "git remote": "allow",
      "git branch *": "allow",
      "git rev-parse *": "allow",
      "git add *": "allow",
      "git commit -m *": "allow",
      "git push *": "allow",
      "git push": "allow",
      "gh auth status": "allow",
      "gh repo view *": "allow",
      "gh repo create *": "allow",
      "gh pr view *": "allow",
      "gh pr list *": "allow",
      "gh pr status *": "allow",
      "gh pr checks *": "allow",
      "sh \"tools/build_oracle.sh\"": "allow",
      "sh tools/build_oracle.sh": "allow",
      "sh tools/*": "allow",
      "./tools/*": "allow",
      "sqlite3 *": "allow",
      "./zig-out/bin/minipro-zig *": "allow",
      "./zig-out/bin/compare_cli *": "allow",
      "zig-out/bin/minipro-zig *": "allow",
      "zig-out/bin/compare_cli *": "allow",
      "\"zig-cache/oracle/minipro-src/minipro\" *": "allow",
      "zig-cache/oracle/minipro-src/minipro *": "allow"
    }
  }
}
